---
import type { DeckSummary } from "@/lib/db";

const { decks } = Astro.props as { decks: DeckSummary[] };
---

<div class="space-y-3">
  {decks.length === 0 && (
    <div class="glass section-card rounded-[1.75rem] px-4 py-5 text-sm text-slate-600">
      还没有牌组。先创建一个 deck，再把 AI 洞见或笔记导入进来。
    </div>
  )}

  {decks.map((deck) => (
    <a
      href={`/decks/${deck.id}`}
      class="glass section-card flex items-center justify-between gap-4 rounded-[1.75rem] px-4 py-4 transition hover:-translate-y-0.5 hover:bg-white/90"
    >
      <div class="min-w-0">
        <div class="flex items-center gap-2">
          <span class="h-2.5 w-2.5 rounded-full bg-[linear-gradient(180deg,#bf6238,#547f9f)]" aria-hidden="true"></span>
          <h3 class="text-base font-semibold text-ink">{deck.name}</h3>
          {deck.archived && <span class="rounded-full bg-slate-200 px-2 py-0.5 text-xs text-slate-600">Archived</span>}
        </div>
        <p class="mt-1 break-words text-sm text-slate-600">{deck.desc || "No description yet."}</p>
      </div>
      <div class="text-right">
        <div class="metric text-2xl font-semibold text-ink">{deck.dueCount}</div>
        <p class="text-xs uppercase tracking-[0.18em] text-slate-500">Due / {deck.totalCards}</p>
      </div>
    </a>
  ))}
</div>
