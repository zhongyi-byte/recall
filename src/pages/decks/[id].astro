---
import Base from "@/layouts/Base.astro";
import { getDeck, listCardsByDeck } from "@/lib/db";
import { requirePageAuth } from "@/lib/auth";
import { getDb } from "@/lib/runtime";

const redirect = requirePageAuth(Astro);
if (redirect) return redirect;

const deckId = Astro.params.id;
const db = getDb(Astro);
const deck = deckId ? await getDeck(db, deckId) : null;
const cards = deckId ? await listCardsByDeck(db, deckId) : [];

if (!deck) {
  Astro.response.status = 404;
}
---

<Base title={`${deck?.name ?? "Deck"} · Recall`} currentPath="/decks">
  {deck ? (
    <>
      <section class="grid gap-6 lg:grid-cols-[1fr_0.9fr]">
        <div class="glass-strong section-card rounded-[2rem] p-6">
          <div class="eyebrow">Deck Detail</div>
          <div class="mt-3 flex flex-wrap items-start justify-between gap-4">
            <div>
              <h1 class="text-3xl font-semibold text-ink text-balance">{deck.name}</h1>
              <p class="mt-3 max-w-2xl text-base text-pretty text-slate-600">{deck.desc || "No description yet."}</p>
            </div>
            <div class="text-right">
              <div class="metric text-5xl font-semibold text-ink">{deck.dueCount}</div>
              <p class="text-sm text-slate-500">Due / {deck.totalCards} cards</p>
            </div>
          </div>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href={`/review?deck=${deck.id}`} class="btn-primary">
              Review this deck
            </a>
            <button
              class="btn-secondary"
              data-archive-toggle
              data-archived={String(deck.archived)}
              type="button"
            >
              {deck.archived ? "Restore deck" : "Archive deck"}
            </button>
          </div>
        </div>

        <div class="glass section-card rounded-[2rem] p-6">
          <div class="eyebrow">Add Card</div>
          <h2 class="mt-2 text-2xl font-semibold text-ink">Web 端手动补卡</h2>
          <form class="mt-6 space-y-4" id="card-form">
            <label class="block">
              <span class="mb-2 block text-sm font-medium text-slate-700">Front</span>
              <textarea class="field min-h-28" name="front" placeholder="写一个可回忆、可唯一回答的问题…" required></textarea>
            </label>
            <label class="block">
              <span class="mb-2 block text-sm font-medium text-slate-700">Back</span>
              <textarea class="field min-h-36" name="back" placeholder="写答案；把辅助细节放在后面…" required></textarea>
            </label>
            <label class="block">
              <span class="mb-2 block text-sm font-medium text-slate-700">Tags</span>
              <input class="field" autocomplete="off" name="tags" placeholder="ai, fsrs…" />
            </label>
            <button class="btn-primary" type="submit">Add Card</button>
            <p aria-live="polite" class="hidden text-sm text-rose-700" id="card-error"></p>
          </form>
        </div>
      </section>

      <section class="mt-6 glass section-card rounded-[2rem] p-6">
        <div class="eyebrow">Cards</div>
        <h2 class="mt-2 text-2xl font-semibold text-ink">卡片预览</h2>
        <div class="mt-5 space-y-4">
          {cards.map((card) => (
            <details class="rounded-[1.5rem] bg-white/82 p-4 shadow-sm">
              <summary class="cursor-pointer list-none text-base font-semibold text-ink">{card.front}</summary>
              <div class="mt-3 space-y-3 text-sm text-slate-600">
                <p><span class="font-medium text-slate-800">Back:</span> {card.back}</p>
                <p><span class="font-medium text-slate-800">State:</span> {card.state}</p>
                <p><span class="font-medium text-slate-800">Due:</span> {card.due}</p>
                <p><span class="font-medium text-slate-800">Tags:</span> {card.tags.join(", ") || "None"}</p>
              </div>
            </details>
          ))}
          {cards.length === 0 && <p class="text-sm text-slate-600">This deck has no cards yet.</p>}
        </div>
      </section>

      <script define:vars={{ deckId: deck.id }}>
        // @ts-nocheck
        const form = document.querySelector("#card-form");
        const errorEl = document.querySelector("#card-error");
        const archiveButton = document.querySelector("[data-archive-toggle]");

        form?.addEventListener("submit", async (event) => {
          event.preventDefault();
          if (!(form instanceof HTMLFormElement) || !(errorEl instanceof HTMLElement)) return;
          errorEl.classList.add("hidden");
          errorEl.textContent = "";
          const formData = new FormData(form);
          const tags = String(formData.get("tags") || "")
            .split(",")
            .map((item) => item.trim())
            .filter(Boolean);

          const response = await fetch("/api/cards", {
            method: "POST",
            headers: {
              "content-type": "application/json"
            },
            body: JSON.stringify({
              deckId,
              front: String(formData.get("front") || ""),
              back: String(formData.get("back") || ""),
              tags
            })
          });

          if (!response.ok) {
            const body = await response.json().catch(() => ({}));
            errorEl.textContent = body.error || "Failed to add card";
            errorEl.classList.remove("hidden");
            return;
          }

          window.location.reload();
        });

        archiveButton?.addEventListener("click", async () => {
          if (!(archiveButton instanceof HTMLButtonElement)) return;
          const archived = archiveButton.dataset.archived === "true";
          const response = await fetch(`/api/decks/${deckId}/archive`, {
            method: "POST",
            headers: {
              "content-type": "application/json"
            },
            body: JSON.stringify({ archived: !archived })
          });

          if (!response.ok) {
            return;
          }

          window.location.reload();
        });
      </script>
    </>
  ) : (
    <div class="glass-strong section-card rounded-[2rem] p-8">
      <div class="eyebrow">Not Found</div>
      <h1 class="mt-2 text-3xl font-semibold text-ink">Deck not found</h1>
      <p class="mt-3 text-slate-600">The requested deck does not exist.</p>
    </div>
  )}
</Base>
